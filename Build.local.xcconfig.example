// Copy this file to Build.local.xcconfig and fill in your own values.
// Build.local.xcconfig is ignored by Git.

TMDB_API_KEY =
ANILIST_CLIENT_ID =
ANILIST_CLIENT_SECRET =
ANILIST_REDIRECT_URI = luna:/$()/anilist-callback
TRAKT_CLIENT_ID =
TRAKT_CLIENT_SECRET =
TRAKT_REDIRECT_URI = luna:/$()/trakt-callback
MAL_CLIENT_ID =
MAL_CLIENT_SECRET =
MAL_REDIRECT_URI = luna:/$()/mal-callback

// MPV Metal fork testing flags.
// Only uncomment these when using an MPVKit fork that exposes Metal sample-buffer PiP frames.
// SWIFT_ACTIVE_COMPILATION_CONDITIONS = $(inherited) ECLIPSE_MPVKIT_FORK_EXPOSES_METAL_SAMPLE_BUFFER_PIP ECLIPSE_MPVKIT_METAL_SAMPLE_BUFFER_PIP_IMPLEMENTED
// Add this only after PGS, VobSub, DVB, and XSUB are validated on the Metal path.
// SWIFT_ACTIVE_COMPILATION_CONDITIONS = $(inherited) ECLIPSE_MPVKIT_FORK_EXPOSES_METAL_SAMPLE_BUFFER_PIP ECLIPSE_MPVKIT_METAL_SAMPLE_BUFFER_PIP_IMPLEMENTED ECLIPSE_MPVKIT_METAL_BITMAP_SUBTITLES_VALIDATED
