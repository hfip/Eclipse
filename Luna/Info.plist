	<string>$(TRAKT_CLIENT_ID)</string>
	<key>TraktClientSecret</key>
	<string>$(TRAKT_CLIENT_SECRET)</string>
	<key>TraktRedirectUri</key>
	<string>$(TRAKT_REDIRECT_URI)</string>
	<key>MALClientID</key>
	<string>$(MAL_CLIENT_ID)</string>
	<key>MALClientSecret</key>
	<string>$(MAL_CLIENT_SECRET)</string>
	<key>MALRedirectUri</key>
	<string>$(MAL_REDIRECT_URI)</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>fetch</string>
		<string>processing</string>
	</array>
</dict>
</plist>
